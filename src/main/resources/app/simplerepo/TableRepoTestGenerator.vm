    @Test
    public void test01() {
        try (Trx trx = DbConnContainer.newTrx()) {
            String uid = UUID.randomUUID().toString().replace("-", "");
            $!{_repo_class_name_} repo = new $!{_repo_class_name_}(trx);

            // -- create -----------------------------------------------------------
            $!{_entity_class_name_} en1 = new $!{_entity_class_name_}();
            en1.$!{_primary_key_setter_}(uid);
$!{_set_not_null_fields_for_create_}            
            repo.create(en1);

            // -- find by key ------------------------------------------------------
            $!{_entity_class_name_} en2 = repo.findByKey(uid);
            if (en2 == null) {
                throw new DbException("Entity not found, findByKey");
            }

            // -- update -----------------------------------------------------------
$!{_set_all_fields_for_update_} 
            repo.update(en2);

            // -- find by autoinc --------------------------------------------------
            $!{_entity_class_name_} en3 = repo.findByAutoinc(en2.$!{_autoinc_key_getter_}());
            if (en3 == null) {
                throw new DbException("Entity not found, findByAutoinc");
            }

            // -- find all ---------------------------------------------------------
            repo.findAll();

            //----------------------------------------------------------------------
            trx.rollback();
        } catch (Exception ex) {
            throw new DbException(ex);
        }
    }

