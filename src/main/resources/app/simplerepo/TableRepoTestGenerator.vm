@Slf4j
public class $!{_test_class_name_} {

    @BeforeEach
    public void init() {
        DbConnContainer.addDbConn(new DbConnConfig("Default",
            Consta.CONN_URL, Consta.CONN_USER, Consta.CONN_PSW, Consta.CONN_DRIVER,
            false, 20, 180000
        ));
